# ==============================================================
# CareDesk - 環境変数サンプル
# このファイルを .env にコピーして実際の値を設定してください
# ==============================================================

# --------------------------------------------------------------
# フロントエンド (Vite / React)
# VITE_ prefix は Vite がブラウザに公開する環境変数
# --------------------------------------------------------------

# FastAPIバックエンドのURL（本番: https://api.caredesk.jp）
VITE_API_BASE_URL=http://localhost:8000/api

# Stripe 公開鍵（フロントエンドで使用）
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# --------------------------------------------------------------
# バックエンド (FastAPI / Python)
# backend/.env に記載するか、同じ .env に統合してください
# --------------------------------------------------------------

# Oracle Autonomous Database 接続情報
ORACLE_USER=caredesk_app
ORACLE_PASSWORD=YourStrongPassword123!
ORACLE_DSN=your-adb-hostname.adb.ap-tokyo-1.oraclecloudapps.com/your_service_name

# JWT 設定（必ず変更すること）
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-min-32chars
JWT_EXPIRE_MINUTES=10080    # 7日間 = 60 * 24 * 7

# CORS 許可オリジン（カンマ区切り）
CORS_ORIGINS=http://localhost:5173,https://caredesk.jp,https://www.caredesk.jp

# Stripe 設定（月額課金）
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx     # ¥3,000/月のPrice ID
